{
  "name": "trading",
  "version": "0.1.0",
  "private": true,
  "description": "Handmade Binance trading interface with a Fastify backend, SolidJS UI, and reusable bot package.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -n server,web -c green,cyan \"npm run dev -w @trading/server\" \"npm run dev -w @trading/web\"",
    "build": "npm run build -w @trading/bot-algo && npm run build -w @trading/server && npm run build -w @trading/web",
    "test": "npm test -w @trading/bot-algo && npm test -w @trading/server",
    "typecheck": "npm run typecheck -w @trading/bot-algo && npm run typecheck -w @trading/server && npm run typecheck -w @trading/web",
    "benchmark:strategies": "tsx scripts/benchmark-strategies.ts",
    "benchmark:sigmoid-sigma": "tsx scripts/benchmark-sigmoid-sigma-fit.ts",
    "benchmark:kama:cuda": "tsx scripts/benchmark-vw-kama-cuda.ts",
    "benchmark:kama:value:cuda": "tsx scripts/benchmark-vw-kama-value-cuda.ts",
    "benchmark:kama:cuda:7d": "tsx scripts/compare-vw-kama-cuda-7d.ts",
    "build:cuda": "node scripts/build-vw-kama-cuda.mjs",
    "search:kama": "tsx scripts/search-volume-weighted-kama.ts",
    "audit:kama": "tsx scripts/audit-vw-kama-global.ts",
    "fetch:candles": "tsx scripts/fetch-binance-spot-candles.ts",
    "verify:risk": "tsx scripts/verify-bot-risk-paths.ts",
    "backtest:pathologies": "tsx scripts/collect-pathological-backtests.ts",
    "experiment:loop": "tsx scripts/experiment-agent-loop.ts",
    "start": "npm run start -w @trading/server"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "concurrently": "^9.1.0",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  }
}
