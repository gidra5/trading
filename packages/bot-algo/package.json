{
  "name": "@trading/bot-algo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "development": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./src/index.ts"
    },
    "./exposure-value-distillation": {
      "types": "./src/exposure-value-distillation.ts",
      "development": "./src/exposure-value-distillation.ts",
      "import": "./dist/exposure-value-distillation.js",
      "default": "./src/exposure-value-distillation.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "node --import tsx --test test/*.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "tsx": "^4.19.2"
  },
  "dependencies": {
    "koffi": "^3.1.1"
  }
}
